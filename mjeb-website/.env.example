# Configuration pour le développement
# Copiez ce fichier vers .env et remplissez les valeurs

# === AUTHENTIFICATION ===
# ID de l'application OAuth
VITE_APP_ID=votre_app_id_oauth

# Secret JWT (minimum 32 caractères)
JWT_SECRET=votre_secret_jwt_tres_long_et_securise_au_minimum_32_caracteres

# URL du serveur OAuth
OAUTH_SERVER_URL=http://localhost:3000

# OpenID du propriétaire
OWNER_OPEN_ID=votre_openid_proprietaire

# === BASE DE DONNÉES ===
# URL de la base de données PostgreSQL
# Format: postgresql://username:password@host:port/database
# Pour développement local avec Docker: postgresql://mjeb_user:mjeb_password@localhost:5432/mjeb
# Pour production: utilisez une base de données managée (Supabase, Railway, etc.)
DATABASE_URL=postgresql://mjeb_user:mjeb_password@localhost:5432/mjeb

# === API EXTERNES (optionnelles) ===
# API Forge pour l'IA
BUILT_IN_FORGE_API_URL=https://api.example.com
BUILT_IN_FORGE_API_KEY=votre_cle_api

# === CONFIGURATION SERVEUR ===
# Port du serveur (optionnel, défaut 3000)
PORT=3002

# === ANALYTICS (optionnels) ===
VITE_ANALYTICS_ENDPOINT=http://localhost:3000
VITE_ANALYTICS_WEBSITE_ID=votre_id_analytics